[extension]
name    = "laceBaseline"
version = "1.0.0"

[config]
# Minimum number of data points before spike detection activates.
# Prevents false positives during warmup.
min_entries = 5

# A metric must exceed this multiple of the rolling average to be
# considered a spike. 3.0 means the value must be >3x the average.
spike_multiplier = 3.0

# Whether to include spiking calls in the rolling average update.
# "include" — always add all calls to the rolling average.
# "skip"    — exclude calls where any metric would spike, preventing
#             one-off anomalies from polluting the baseline.
spike_action = "include"
