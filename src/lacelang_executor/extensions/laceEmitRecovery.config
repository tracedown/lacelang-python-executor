[extension]
name    = "laceEmitRecovery"
version = "1.0.0"

[config]
# Default message emitted on recovery. Override with a custom
# notification_val in lace.config to use templates or structured data.
recovery_message = "Service recovered"

# Optional: override the entire notification value.
# Uncomment to use a named template instead of the default text:
#   notification = template("service-recovered")
