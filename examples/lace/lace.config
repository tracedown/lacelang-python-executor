# Base config — used by all environments unless overridden.

[executor]
extensions = ["laceNotifications"]
maxRedirects = 10
maxTimeoutMs = 300000

[result]
path = "."

[result.bodies]
dir = "bodies"

[extensions.laceNotifications]
level = "all"

# ── Environment overrides ───────────────────────────────────────
# Selected by: LaceExecutor(env="staging") or LACE_ENV=staging.
#
# Each [lace.config.{env}] section is deep-merged on top of the
# base sections above.  Only the keys you specify are overridden —
# everything else is inherited from the base.

[lace.config.staging]

[lace.config.staging.executor]
# Staging has a lower timeout ceiling
maxTimeoutMs = 60000

[lace.config.production]

[lace.config.production.executor]
user_agent = "lace-probe/0.9.1 (acme-platform)"
